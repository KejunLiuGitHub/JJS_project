# nbstripout: strip notebook outputs on commit for clean diffs
*.ipynb filter=nbstripout
*.zpln filter=nbstripout
*.ipynb diff=ipynb

# Git LFS: track binary outputs and large files
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.pdf filter=lfs diff=lfs merge=lfs -text
*.gif filter=lfs diff=lfs merge=lfs -text
# Raw data files (optional; uncomment if they grow large)
# *.spm filter=lfs diff=lfs merge=lfs -text
# *.txt filter=lfs diff=lfs merge=lfs -text
*.png !text !filter !merge !diff
*.jpg !text !filter !merge !diff
*.jpeg !text !filter !merge !diff
*.pdf !text !filter !merge !diff
*.gif !text !filter !merge !diff
